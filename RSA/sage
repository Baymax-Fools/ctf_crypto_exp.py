# ---------- 工具 ----------
def crt_pair(a1, n1, a2, n2):
    """使用 SageMath 内置的 xgcd 函数"""
    g, m1, m2 = xgcd(n1, n2)
    if (a1 - a2) % g != 0:
        raise ValueError("CRT 无解")
    lcm_n = lcm(n1, n2)
    t = ((a2 - a1) // g) * inverse_mod(n1 // g, n2 // g) % (n2 // g)
    x = (a1 + n1 * t) % lcm_n
    return x

def crt(list_a, list_n):
    """中国剩余定理实现"""
    x, m = list_a[0], list_n[0]
    for i in range(1, len(list_a)):
        x = crt_pair(x, m, list_a[i], list_n[i])
        m = lcm(m, list_n[i])
    return x

# ---------- 在单个素数上处理 ----------
def process_prime_sage(name, prime, e_global, c_global, initial_g):
    print(f"\n=== 处理 {name} (p={prime}) ===")
    e_local = e_global // initial_g
    t_local = (prime - 1) // initial_g
    print(f"初始 e_local = {e_local}")
    print(f"初始 t_local = {t_local}")

    removed_product = 1
    while True:
        g = gcd(e_local, t_local)
        if g == 1:
            break
        removed_product *= g
        e_local //= g
        t_local //= g
        print(f"  约掉 gcd={g}, removed_product = {removed_product}, e_local = {e_local}")

    d_local = inverse_mod(e_local, t_local)
    a_local = power_mod(c_global, d_local, prime)
    print(f"计算得到 a_local = {a_local}")
    K = initial_g * removed_product
    print(f"总开根次数 K = {K}")

    # 在有限域上求解方程
    F = GF(prime)
    R = PolynomialRing(F, 'x')
    x = R.gen()
    poly = x**K - F(a_local)
    roots = poly.roots(multiplicities=False)
    print(f"在 GF({name}) 上找到根数量: {len(roots)}")

    roots_int = [ZZ(r) for r in roots]
    return a_local, roots_int

